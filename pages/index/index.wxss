.home-page {
  background: #f5f6fa;
}

.home-header {
  padding: 24rpx 28rpx 30rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f9faff 100%);
}

.location-row,
.header-actions,
.search-box,
.identity-card,
.identity-title-row,
.notice-card,
.category-grid,
.filter-row,
.shortcut-row,
.shortcut-card,
.jobs-head,
.job-card__meta,
.job-card__title-row,
.publisher-row,
.job-card__tags,
.job-card__actions {
  display: flex;
  align-items: center;
}

.location-row,
.jobs-head,
.job-card__title-row {
  justify-content: space-between;
}

.location-pill {
  display: flex;
  align-items: center;
  color: #1e273a;
  font-size: 30rpx;
  font-weight: 650;
}

.location-pill__pin {
  margin-right: 10rpx;
  color: #3478f6;
  font-size: 18rpx;
}

.location-pill__arrow {
  margin-left: 8rpx;
  color: #929aaa;
  font-size: 24rpx;
}

.header-actions {
  padding: 6rpx;
  background: #f2f4f8;
  border-radius: 999rpx;
}

.header-action {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 42rpx;
  color: #4d5668;
  font-size: 22rpx;
}

.header-action + .header-action {
  border-left: 1rpx solid #dfe3eb;
}

.search-box {
  height: 84rpx;
  margin-top: 24rpx;
  padding: 0 22rpx;
  background: #f0f2f7;
  border: 2rpx solid #eceff5;
  border-radius: 24rpx;
}

.search-box__icon {
  margin-right: 14rpx;
  color: #7d8798;
  font-size: 34rpx;
}

.search-box__input {
  flex: 1;
  height: 80rpx;
  color: #20283a;
  font-size: 26rpx;
}

.search-box__placeholder {
  color: #a6adba;
}

.search-box__clear {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  color: #ffffff;
  font-size: 28rpx;
  background: #b6bdca;
  border-radius: 50%;
}

.home-content {
  padding: 24rpx 24rpx 0;
}

.identity-card {
  min-height: 142rpx;
  padding: 24rpx;
  color: #ffffff;
  background: linear-gradient(120deg, #2d78f5 0%, #54a8ff 100%);
  border-radius: 28rpx;
  box-shadow: 0 16rpx 32rpx rgba(52, 120, 246, 0.22);
}

.identity-card__avatar {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  margin-right: 18rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  border-radius: 50%;
}

.identity-card__main {
  flex: 1;
  min-width: 0;
}

.identity-card__title {
  font-size: 28rpx;
  font-weight: 650;
}

.identity-card__verified {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28rpx;
  height: 28rpx;
  margin-left: 8rpx;
  color: #287df5;
  font-size: 18rpx;
  font-weight: 700;
  background: #9ff0bd;
  border-radius: 50%;
}

.identity-card__phone {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.74);
  font-size: 21rpx;
}

.identity-card__cert {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 0 16rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 19rpx;
}

.identity-card__cert-icon {
  margin-bottom: 4rpx;
  font-size: 32rpx;
}

.credit-button {
  width: 118rpx;
  height: 64rpx;
  margin: 0;
  padding: 0 12rpx;
  color: #2164d1;
  font-size: 21rpx;
  line-height: 64rpx;
  background: rgba(255, 255, 255, 0.84);
  border-radius: 18rpx;
}

.notice-card {
  min-height: 82rpx;
  margin-top: 18rpx;
  padding: 0 20rpx;
  background: #ffffff;
  border: 1rpx solid #eef0f5;
  border-radius: 22rpx;
  box-shadow: 0 10rpx 24rpx rgba(34, 49, 79, 0.04);
}

.notice-card__icon {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  margin-right: 14rpx;
  font-size: 21rpx;
  border-radius: 12rpx;
}

.notice-card__icon--blue {
  color: #3478f6;
  background: #eaf2ff;
}

.notice-card__icon--orange {
  color: #ec9c2c;
  background: #fff4df;
}

.notice-card__text {
  flex: 1;
  min-width: 0;
  color: #40485a;
  font-size: 23rpx;
}

.notice-card__button,
.notice-card__status {
  margin-left: 12rpx;
  padding: 8rpx 16rpx;
  font-size: 20rpx;
  border-radius: 12rpx;
}

.notice-card__button {
  color: #3478f6;
  border: 1rpx solid #3478f6;
}

.notice-card__status {
  color: #d4861f;
  background: #fff7e8;
  border: 1rpx solid #f3bf6b;
}

.promo-card {
  position: relative;
  overflow: hidden;
  min-height: 190rpx;
  margin-top: 18rpx;
  padding: 32rpx 30rpx;
  color: #ffffff;
  background: linear-gradient(120deg, #152c54 0%, #35629a 55%, #7ca8ce 100%);
  border-radius: 28rpx;
}

.promo-card__glow {
  position: absolute;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.promo-card__glow--one {
  top: -120rpx;
  right: 70rpx;
  width: 300rpx;
  height: 300rpx;
}

.promo-card__glow--two {
  right: -40rpx;
  bottom: -150rpx;
  width: 330rpx;
  height: 330rpx;
}

.promo-card__copy {
  position: relative;
  z-index: 2;
}

.promo-card__eyebrow,
.promo-card__title,
.promo-card__meta {
  display: block;
}

.promo-card__eyebrow {
  color: rgba(255, 255, 255, 0.7);
  font-size: 20rpx;
}

.promo-card__title {
  margin-top: 12rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.promo-card__meta {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 20rpx;
}

.promo-card__art {
  position: absolute;
  right: 28rpx;
  bottom: 10rpx;
  width: 150rpx;
  height: 150rpx;
}

.promo-book {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 126rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
  background: linear-gradient(145deg, #4e74aa, #143a72);
  border: 4rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 8rpx;
  box-shadow: 0 12rpx 24rpx rgba(5, 22, 52, 0.3);
  transform: rotate(8deg);
  white-space: pre-line;
}

.promo-book--back {
  top: 12rpx;
  left: 10rpx;
  background: #d8b97b;
  transform: rotate(-8deg);
}

.promo-book--front {
  right: 4rpx;
  bottom: 0;
}

.promo-card__ad {
  position: absolute;
  right: 14rpx;
  bottom: 12rpx;
  padding: 2rpx 8rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 16rpx;
  background: rgba(0, 0, 0, 0.18);
  border-radius: 8rpx;
}

.category-grid {
  margin: 20rpx -8rpx 0;
}

.category-card {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 170rpx;
  margin: 0 8rpx;
  background: #ffffff;
  border: 2rpx solid transparent;
  border-radius: 26rpx;
  box-shadow: 0 10rpx 24rpx rgba(34, 49, 79, 0.05);
}

.category-card--active {
  background: #f7faff;
  border-color: #75aaf8;
}

.category-card__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  margin-bottom: 16rpx;
  font-size: 36rpx;
  border-radius: 24rpx;
}

.category-card__icon--blue {
  color: #3478f6;
  background: #edf4ff;
}

.category-card__icon--purple {
  color: #6558df;
  background: #f0efff;
}

.category-card__icon--green {
  color: #25a766;
  background: #edfbf3;
}

.category-card__label {
  color: #2d3548;
  font-size: 24rpx;
  font-weight: 600;
}

.filter-scroll {
  width: 100%;
  margin-top: 22rpx;
  white-space: nowrap;
}

.filter-row {
  width: max-content;
  padding-right: 16rpx;
}

.filter-picker {
  display: inline-block;
  margin-right: 14rpx;
}

.filter-chip {
  display: flex;
  align-items: center;
  min-width: 126rpx;
  height: 62rpx;
  padding: 0 20rpx;
  color: #525b6e;
  font-size: 22rpx;
  background: #ffffff;
  border: 1rpx solid #e8ebf1;
  border-radius: 999rpx;
}

.filter-chip--active {
  color: #ffffff;
  background: #3478f6;
  border-color: #3478f6;
}

.filter-chip__arrow {
  margin-left: 12rpx;
  font-size: 18rpx;
}

.shortcut-row {
  margin: 22rpx -8rpx 0;
}

.shortcut-card {
  flex: 1;
  justify-content: space-between;
  min-height: 126rpx;
  margin: 0 8rpx;
  padding: 22rpx 20rpx 22rpx 24rpx;
  border-radius: 26rpx;
}

.shortcut-card--map {
  background: linear-gradient(135deg, #eaf4ff, #f8fbff);
  border: 1rpx solid #d8eaff;
}

.shortcut-card--publish {
  background: linear-gradient(135deg, #f0efff, #faf9ff);
  border: 1rpx solid #e3e0ff;
}

.shortcut-card__title,
.shortcut-card__copy {
  display: block;
}

.shortcut-card__title {
  color: #263047;
  font-size: 26rpx;
  font-weight: 650;
}

.shortcut-card__copy {
  margin-top: 8rpx;
  color: #8a92a2;
  font-size: 20rpx;
}

.shortcut-card__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  color: #3478f6;
  font-size: 34rpx;
  background: rgba(255, 255, 255, 0.84);
  border-radius: 20rpx;
}

.shortcut-card--publish .shortcut-card__icon {
  color: #6255dc;
}

.jobs-head {
  min-height: 126rpx;
  padding: 18rpx 4rpx 8rpx;
}

.jobs-head__title {
  color: #20283a;
  font-size: 32rpx;
  font-weight: 700;
}

.jobs-head__count {
  margin-left: 14rpx;
  color: #3478f6;
  font-size: 20rpx;
  font-weight: 500;
}

.jobs-head__filter {
  color: #7e8798;
  font-size: 22rpx;
}

.job-card {
  overflow: hidden;
  margin-bottom: 20rpx;
  background: #ffffff;
  border: 1rpx solid #eceff4;
  border-radius: 30rpx;
  box-shadow: 0 14rpx 34rpx rgba(36, 54, 91, 0.06);
}

.job-card__top {
  padding: 28rpx 28rpx 22rpx;
}

.job-card__meta {
  color: #8b93a2;
  font-size: 20rpx;
}

.job-card__code {
  margin-right: 12rpx;
  padding: 3rpx 10rpx;
  background: #f4f5f8;
  border-radius: 8rpx;
}

.job-card__location {
  color: #25a363;
  font-weight: 600;
}

.job-card__title-row {
  align-items: flex-start;
  margin-top: 16rpx;
}

.job-card__title {
  flex: 1;
  padding-right: 18rpx;
  color: #20283a;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.45;
}

.job-card__price {
  flex: 0 0 auto;
  color: #ef8c22;
  font-size: 34rpx;
  font-weight: 750;
}

.job-card__unit {
  margin-left: 4rpx;
  color: #8d94a2;
  font-size: 18rpx;
  font-weight: 400;
}

.publisher-row {
  margin-top: 20rpx;
  color: #555d6d;
  font-size: 21rpx;
}

.publisher-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  margin-right: 10rpx;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 700;
  background: linear-gradient(145deg, #f4c35b, #e68b36);
  border-radius: 50%;
}

.publisher-verified {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 24rpx;
  height: 24rpx;
  margin-left: 8rpx;
  color: #ffffff;
  font-size: 15rpx;
  background: #3478f6;
  border-radius: 50%;
}

.job-card__description {
  display: block;
  margin-top: 18rpx;
  color: #687082;
  font-size: 22rpx;
  line-height: 1.75;
}

.job-card__tags {
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.tag {
  margin: 0 10rpx 8rpx 0;
  padding: 7rpx 14rpx;
  font-size: 19rpx;
  border-radius: 9rpx;
}

.tag--neutral {
  color: #70798a;
  background: #f3f4f6;
}

.tag--blue {
  color: #3478f6;
  background: #eaf2ff;
}

.tag--red {
  color: #e35b55;
  background: #fff0ef;
}

.tag--green {
  color: #1f9f60;
  background: #eaf8f0;
}

.tag--purple {
  color: #6a56d8;
  background: #f0edff;
}

.tag--outline {
  color: #8b93a2;
  background: #ffffff;
  border: 1rpx solid #e4e7ed;
}

.job-card__actions {
  padding: 18rpx 24rpx 24rpx;
  border-top: 1rpx solid #f0f2f6;
}

.apply-button {
  flex: 1;
  height: 82rpx;
  margin: 0 16rpx 0 0;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 82rpx;
  background: linear-gradient(90deg, #3478f6, #4c57ed);
  border-radius: 22rpx;
  box-shadow: 0 10rpx 20rpx rgba(52, 120, 246, 0.22);
}

.apply-button--pending {
  background: linear-gradient(90deg, #27ad62, #1abc6c);
  box-shadow: 0 10rpx 20rpx rgba(31, 168, 94, 0.2);
}

.icon-button {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 82rpx;
  height: 82rpx;
  margin: 0 0 0 12rpx;
  padding: 0;
  color: #697286;
  font-size: 32rpx;
  line-height: 82rpx;
  background: #f7f8fa;
  border: 1rpx solid #e9ecf1;
  border-radius: 22rpx;
}

.icon-button--favorite {
  color: #ef6b63;
  background: #fff1f0;
}

.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 30rpx;
  background: #ffffff;
  border-radius: 28rpx;
}

.empty-card__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 104rpx;
  color: #78a5ef;
  font-size: 48rpx;
  background: #eef5ff;
  border-radius: 34rpx;
}

.empty-card__title {
  margin-top: 24rpx;
  color: #2b3447;
  font-size: 27rpx;
  font-weight: 650;
}

.empty-card__copy {
  margin-top: 10rpx;
  color: #9299a8;
  font-size: 21rpx;
}

.empty-card__button {
  width: 250rpx;
  height: 72rpx;
  margin-top: 30rpx;
  color: #3478f6;
  font-size: 23rpx;
  line-height: 72rpx;
  background: #edf4ff;
  border-radius: 999rpx;
}

.list-end {
  padding: 36rpx 0 12rpx;
  color: #a8aeba;
  font-size: 20rpx;
  text-align: center;
}

.role-indicator { color: #42618f; font-size: 22rpx; font-weight: 700; }
.identity-card__avatar--image, .publisher-avatar--image { padding: 0; overflow: hidden; }
.page-state { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 320rpx; padding: 48rpx 24rpx; color: #7c869a; font-size: 24rpx; text-align: center; }
.page-state__title { margin-bottom: 12rpx; color: #2c3750; font-size: 30rpx; font-weight: 700; }
.page-state button { min-width: 200rpx; margin-top: 28rpx; color: #fff; font-size: 24rpx; background: #3478f6; border-radius: 999rpx; }
.state-spinner { width: 42rpx; height: 42rpx; margin-bottom: 20rpx; border: 5rpx solid #dce7fb; border-top-color: #3478f6; border-radius: 50%; animation: state-spin 800ms linear infinite; }
@keyframes state-spin { to { transform: rotate(360deg); } }
@media (max-width: 340px) {
  .home-content { padding-right: 20rpx; padding-left: 20rpx; }
  .identity-card { flex-wrap: wrap; }
  .credit-button { margin-top: 14rpx; }
  .job-card__title-row { align-items: flex-start; flex-direction: column; }
}
