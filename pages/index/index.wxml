<view class="page-with-tabbar home-page">
  <view class="home-header">
    <view class="location-row"><view class="location-pill"><text class="location-pill__pin">●</text><text>{{locationLabel}}</text></view><text class="role-indicator">{{roleName}}</text></view>
  </view>
  <view class="home-content">
    <view class="identity-card" wx:if="{{account}}">
      <image wx:if="{{account.avatarUrl}}" class="identity-card__avatar identity-card__avatar--image" src="{{account.avatarUrl}}" mode="aspectFill" />
      <view wx:else class="identity-card__avatar">{{accountInitial}}</view>
      <view class="identity-card__main" bindtap="goProfile"><text class="identity-card__title">{{account.nickname || '微信用户'}}</text><text class="identity-card__phone">{{verificationLabel}}</text></view>
      <button class="credit-button" loading="{{actionId === 'role'}}" bindtap="switchRole">切换{{activeRole === 'TEACHER' ? '家长' : '老师'}}版</button>
    </view>
    <view class="platform-card">
      <view class="platform-card__heading"><view class="platform-card__mascot">✦</view><view><text class="platform-card__title">{{platformOverview ? platformOverview.brand.name : '平台公开信息'}}</text><text class="platform-card__slogan" wx:if="{{platformOverview}}">{{platformOverview.brand.slogan}}</text><text class="platform-card__slogan" wx:else>{{platformOverviewLoading ? '正在读取平台概览' : '公开信息暂时不可用'}}</text></view></view>
      <view class="platform-card__state" wx:if="{{platformOverviewLoading}}"><view class="platform-card__dots"><text></text><text></text><text></text></view><text>正在更新平台概览，不影响浏览信息</text></view>
      <view class="platform-card__state platform-card__state--error" wx:elif="{{platformOverviewError}}"><view><text class="platform-card__state-title">概览暂时没有赶上</text><text class="platform-card__state-copy">{{platformOverviewError}}</text></view><button bindtap="retryPlatformOverview">重新获取</button></view>
      <block wx:elif="{{platformOverview}}">
        <view class="platform-metrics"><view class="platform-metric" wx:for="{{platformMetricItems}}" wx:key="key"><view><text class="platform-metric__value">{{item.displayValue}}</text><text class="platform-metric__unit">{{item.unit}}</text></view><text class="platform-metric__label">{{item.label}}</text></view></view>
        <view class="trust-highlights"><text wx:for="{{platformOverview.trustHighlights}}" wx:key="*this">✓ {{item}}</text></view>
      </block>
    </view>
    <view class="search-section"><view class="search-section__head"><view><text>搜索家教信息</text><text>支持标题、科目、年级、区域、学生情况和发布人</text></view><text>{{resultCopy}}</text></view><view class="search-box"><text class="search-box__icon">⌕</text><input class="search-box__input" value="{{query}}" placeholder="输入数学、初三、南山区等关键词" placeholder-class="search-box__placeholder" confirm-type="search" bindinput="handleSearch" /><view wx:if="{{query}}" class="search-box__clear" bindtap="clearSearch">×</view></view></view>
    <scroll-view class="subject-scroll" scroll-x enhanced show-scrollbar="false"><view class="category-grid"><view wx:for="{{quickSubjects}}" wx:key="label" class="category-card {{item.active ? 'category-card--active' : ''}}" data-subject="{{item.label}}" bindtap="chooseSubject" hover-class="pressable--active"><view class="category-card__icon category-card__icon--blue">{{item.icon}}</view><text class="category-card__label">{{item.label}}</text><text class="category-card__check">{{item.active ? '已选' : '可多选'}}</text></view></view></scroll-view>
    <scroll-view class="filter-scroll" scroll-x enhanced show-scrollbar="false"><view class="filter-row"><picker wx:for="{{filterLabels}}" wx:key="*this" class="filter-picker" range="{{filterOptions[index]}}" value="{{filterIndexes[index]}}" data-position="{{index}}" bindchange="handleFilterChange"><view class="filter-chip {{filterIndexes[index] > 0 ? 'filter-chip--active' : ''}}"><text>{{item}}</text><text class="filter-chip__arrow">⌄</text></view></picker></view></scroll-view>
    <view class="shortcut-row"><view class="shortcut-card shortcut-card--map" bindtap="goMap" hover-class="pressable--active"><view><text class="shortcut-card__title">地图寻单</text><text class="shortcut-card__copy">按真实距离查看</text></view><view class="shortcut-card__icon">⌖</view></view><view class="shortcut-card shortcut-card--publish" bindtap="goPublish" hover-class="pressable--active"><view><text class="shortcut-card__title">发布信息</text><text class="shortcut-card__copy">提交平台审核</text></view><view class="shortcut-card__icon">＋</view></view></view>
    <view class="jobs-head"><view><text class="jobs-head__title">{{activeRole === 'TEACHER' ? '最新家教需求' : '认证老师求带'}}</text><text class="jobs-head__count">{{resultCopy}}</text></view><view class="jobs-head__filter" bindtap="resetFilters">重置筛选</view></view>
    <view class="page-state" wx:if="{{loading}}"><view class="state-spinner"></view><text>正在为你寻找合适的信息...</text></view>
    <view class="page-state page-state--error" wx:elif="{{error}}"><text class="page-state__title">加载失败</text><text>{{error}}</text><button bindtap="retry">重新加载</button></view>
    <view class="job-list" wx:elif="{{filteredJobs.length}}">
      <view class="job-card" wx:for="{{filteredJobs}}" wx:key="id">
        <view class="job-card__top" data-id="{{item.id}}" bindtap="openDetail">
          <view class="job-card__meta"><text class="job-card__code">{{item.typeLabel}}</text><text class="job-card__location">{{item.locationLabel || '地点待沟通'}}</text></view>
          <view class="job-card__title-row"><text class="job-card__title">{{item.title}}</text><view class="job-card__price"><text>{{item.price}}</text><text class="job-card__unit">{{item.unit}}</text></view></view>
          <view class="publisher-row"><image wx:if="{{item.publisherAvatar}}" class="publisher-avatar publisher-avatar--image" src="{{item.publisherAvatar}}" mode="aspectFill" /><view wx:else class="publisher-avatar">{{item.publisherInitial}}</view><text>发布人：{{item.publisher}}</text></view>
          <text class="job-card__description">{{item.description}}</text>
          <view class="job-card__tags"><text class="tag tag--neutral">{{item.settlement || '结算待沟通'}}</text><text class="tag tag--blue">{{item.grade}}</text><text class="tag tag--outline">{{item.distance || item.subject}}</text></view>
        </view>
        <view class="job-card__actions">
          <button class="icon-button {{item.favorite ? 'icon-button--favorite' : ''}}" loading="{{actionId === 'favorite-' + item.id}}" data-id="{{item.id}}" bindtap="toggleFavorite" aria-label="{{item.favorite ? '取消收藏' : '收藏'}}：{{item.title}}"><text class="icon-button__icon">{{item.favorite ? '♥' : '♡'}}</text><text class="icon-button__label">{{item.favorite ? '已收藏' : '收藏'}}</text></button>
          <button class="icon-button" open-type="share" data-id="{{item.id}}" aria-label="分享：{{item.title}}"><text class="icon-button__icon">↗</text><text class="icon-button__label">分享</text></button>
        </view>
      </view>
    </view>
    <view class="empty-card" wx:else><view class="empty-card__icon">⌕</view><text class="empty-card__title">暂时没有匹配信息</text><text class="empty-card__copy">换个科目或区域看看，新的发布也许正在路上</text><button class="empty-card__button" bindtap="resetFilters">查看全部</button></view>
  </view>
</view>
