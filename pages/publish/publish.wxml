<view class="page-with-tabbar publish-page">
  <view class="publish-hero"><text class="publish-hero__eyebrow">{{roleName}} · 数据由平台统一保存</text><text class="publish-hero__title">{{activeRole === 'TEACHER' ? '发布老师求带' : '发布家教需求'}}</text><text class="publish-hero__copy">审核通过后才会公开展示，联系方式默认隐藏</text><view class="publish-hero__shield">✓</view></view>
  <view class="publish-content">
    <view class="publish-state" wx:if="{{loading}}"><view class="publish-spinner"></view><text>正在加载发布记录...</text></view>
    <view class="publish-state" wx:elif="{{error}}"><text class="publish-state__title">加载失败</text><text>{{error}}</text><button bindtap="retry">重新加载</button></view>
    <block wx:else>
      <view class="type-switch"><view class="type-option {{publishType === 'offer' ? 'type-option--active' : ''}}" data-type="offer" bindtap="switchType"><text class="type-option__icon">🎓</text><view><text class="type-option__title">老师求带</text><text class="type-option__copy">老师 / 大学生</text></view></view><view class="type-option {{publishType === 'need' ? 'type-option--active' : ''}}" data-type="need" bindtap="switchType"><text class="type-option__icon">⌂</text><view><text class="type-option__title">家教需求</text><text class="type-option__copy">家长 / 招聘方</text></view></view></view>
      <view class="edit-banner" wx:if="{{editingId}}"><text>{{editingPublished ? '正在申请修改已发布信息；审核期间原内容继续展示' : '正在编辑退回/待审记录，提交后将重新审核'}}</text><text bindtap="cancelEdit">取消编辑</text></view>
      <view class="form-card">
        <view class="form-section-head"><view class="form-section-head__number">1</view><view><text class="form-section-head__title">基本信息</text><text class="form-section-head__copy">带 * 的内容为必填项</text></view></view>
        <view class="form-field"><text class="form-label">标题 *</text><input class="form-input" value="{{form.title}}" maxlength="60" data-field="title" placeholder="清楚说明年级、科目和安排" bindinput="handleInput" /></view>
        <view class="form-grid"><picker class="form-picker" range="{{teachingModes}}" value="{{modeIndex}}" bindchange="handleModePicker"><view class="form-select"><text class="form-select__label">授课方式 *</text><text class="form-select__value">{{teachingModes[modeIndex]}}</text></view></picker><picker class="form-picker" range="{{grades}}" value="{{gradeIndex}}" data-field="grade" bindchange="handlePicker"><view class="form-select"><text class="form-select__label">年级 *</text><text class="form-select__value">{{form.grade || '请选择'}}</text></view></picker></view>
        <picker wx:if="{{!isOnline}}" mode="region" value="{{regionValue}}" bindchange="handleRegionPicker"><view class="region-select"><view><text class="form-select__label">省 / 市 / 区 *</text><text class="form-select__value">{{form.district ? form.province + ' · ' + form.city + ' · ' + form.district : '使用标准滚动控件选择'}}</text></view><text>⌄</text></view></picker>
        <view class="form-grid"><picker class="form-picker" range="{{subjects}}" value="{{subjectIndex}}" data-field="subject" bindchange="handlePicker"><view class="form-select"><text class="form-select__label">科目 *</text><text class="form-select__value">{{form.subject || '请选择'}}</text></view></picker><view class="form-field form-field--half"><text class="form-label form-label--small">课酬 *</text><view class="price-input-wrap"><text>¥</text><input class="price-input" value="{{form.price}}" type="digit" maxlength="8" data-field="price" placeholder="200" bindinput="handleInput" /><text class="price-input-wrap__unit">/小时</text></view></view></view>
        <view class="form-grid"><picker class="form-picker" range="{{settlements}}" value="{{settlementIndex}}" data-field="settlement" bindchange="handlePicker"><view class="form-select"><text class="form-select__label">结算方式</text><text class="form-select__value">{{form.settlement}}</text></view></picker><view class="location-select" bindtap="chooseLocation"><text>地图搜索地点 *</text><text>{{form.latitude ? '重新选择 ›' : isOnline ? '线上授课' : '搜索地址 ›'}}</text></view></view>
        <view class="selected-location" wx:if="{{!isOnline}}" bindtap="chooseLocation"><text class="selected-location__name">{{form.area || '尚未选择详细地点'}}</text><text class="selected-location__address">{{form.address || '点击后可输入地点名称并在地图搜索结果中选择'}}</text></view>
        <view class="form-field"><text class="form-label">可授课时间 *</text><input class="form-input" value="{{form.schedule}}" maxlength="100" data-field="schedule" placeholder="例如：周六、周日 14:00–18:00" bindinput="handleInput" /></view>
      </view>
      <view class="form-card">
        <view class="form-section-head"><view class="form-section-head__number">2</view><view><text class="form-section-head__title">详细说明</text><text class="form-section-head__copy">介绍经验、要求或学生情况</text></view></view>
        <view class="form-field"><textarea class="form-textarea" value="{{form.description}}" maxlength="1000" data-field="description" placeholder="请描述教学经验、要求和课程目标..." bindinput="handleInput"></textarea><text class="form-count">{{form.description.length || 0}} / 1000</text></view>
        <view class="form-field" wx:if="{{publishType === 'need'}}"><text class="form-label">学生情况</text><input class="form-input" value="{{form.studentInfo}}" maxlength="200" data-field="studentInfo" placeholder="基础、人数等信息" bindinput="handleInput" /></view>
        <view class="form-field"><text class="form-label">联系方式 *</text><input class="form-input" value="{{form.contact}}" maxlength="20" data-field="contact" placeholder="手机号或微信号" bindinput="handleInput" /><text class="privacy-note">平台加密保存，匹配前不公开展示</text></view>
      </view>
      <button class="submit-button" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submitForm">{{editingId ? '保存并重新提交' : '提交平台审核'}}</button>
      <view class="my-posts">
        <view class="my-posts__head"><text class="my-posts__title">我的发布</text><text class="my-posts__count">{{posts.length}} 条</text></view>
        <view class="post-card" wx:for="{{posts}}" wx:key="id"><view class="post-card__status">{{item.statusLabel}}</view><text class="post-card__title">{{item.title}}</text><text class="post-card__meta">{{item.locationLabel}} · {{item.grade}} · {{item.subject}} · ¥{{item.price}}{{item.unit}}</text><text class="post-card__note" wx:if="{{item.auditNote}}">审核意见：{{item.auditNote}}</text><text class="post-card__note post-card__note--pending" wx:if="{{item.pendingRevision}}">修改申请审核中，当前已发布内容保持不变</text><view class="post-card__footer"><text>{{item.createdLabel}}</text><view class="post-actions"><text wx:if="{{(item.status === 'DRAFT' || item.status === 'PENDING' || item.status === 'REJECTED' || item.status === 'PUBLISHED') && !item.pendingRevision}}" data-id="{{item.id}}" bindtap="editPost">{{item.status === 'PUBLISHED' ? '申请修改' : '编辑'}}</text><text wx:if="{{activeRole === 'PARENT' && item.type === 'TEACHING_NEED'}}" data-id="{{item.id}}" bindtap="manageApplications">报名管理</text><text class="post-card__remove" data-id="{{item.id}}" bindtap="togglePostStatus">{{actionId === item.id ? '处理中...' : item.status === 'CLOSED' ? '重新提交' : '关闭'}}</text></view></view></view>
        <view class="posts-empty" wx:if="{{!posts.length}}">数据库中还没有你的发布记录</view>
      </view>
    </block>
  </view>
</view>
