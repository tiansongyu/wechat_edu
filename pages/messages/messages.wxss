.messages-page {
  padding-right: 24rpx;
  padding-left: 24rpx;
  background: #f5f6fa;
}

.messages-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 38rpx 8rpx 26rpx;
}

.messages-header__main { min-width: 0; }

.messages-header__identity {
  display: flex;
  align-items: center;
}

.messages-header__eyebrow {
  display: block;
  color: #7f899b;
  font-size: 24rpx;
}

.messages-role {
  display: inline-flex;
  align-items: center;
  height: 38rpx;
  margin-left: 12rpx;
  padding: 0 13rpx;
  font-size: 20rpx;
  font-weight: 650;
  border-radius: 999rpx;
}

.messages-role--parent {
  color: #4c6fc4;
  background: #eaf1ff;
}

.messages-role--teacher {
  color: #7753b8;
  background: #f1eaff;
}

.messages-header__title-row {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.messages-header__title {
  color: #1e273a;
  font-size: 44rpx;
  font-weight: 750;
}

.messages-header__badge {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 40rpx;
  height: 40rpx;
  margin-left: 12rpx;
  padding: 0 11rpx;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  background: #ef625b;
  border-radius: 999rpx;
}

.messages-header__action {
  flex: 0 0 auto;
  width: auto;
  min-width: 152rpx;
  height: 76rpx;
  margin: 0 0 2rpx 18rpx;
  padding: 0 24rpx;
  color: #3478f6;
  font-size: 24rpx;
  line-height: 76rpx;
  background: #edf4ff;
  border-radius: 999rpx;
}

.messages-header__action[disabled] {
  color: #8b9ab4;
  background: #e9edf3;
}

.message-tools {
  display: flex;
  margin: 0 -8rpx;
}

.message-tool {
  display: flex;
  flex: 1;
  align-items: center;
  min-width: 0;
  min-height: 124rpx;
  margin: 0 8rpx;
  padding: 20rpx;
  background: #fff;
  border: 1rpx solid #ebedf2;
  border-radius: 26rpx;
  box-shadow: 0 10rpx 26rpx rgba(41, 56, 88, 0.05);
}

.message-tool__icon {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  margin-right: 15rpx;
  font-size: 32rpx;
  border-radius: 22rpx;
}

.message-tool__icon--blue {
  color: #3478f6;
  background: linear-gradient(145deg, #edf5ff, #e4edff);
}

.message-tool__icon--purple {
  color: #6a56d8;
  background: linear-gradient(145deg, #f3efff, #ece8ff);
}

.message-tool__title,
.message-tool__copy { display: block; }

.message-tool__title {
  overflow: hidden;
  color: #2a3347;
  font-size: 25rpx;
  font-weight: 650;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.message-tool__copy {
  margin-top: 6rpx;
  color: #858fa1;
  font-size: 22rpx;
}

.message-tabs {
  display: flex;
  align-items: center;
  margin-top: 28rpx;
  padding: 7rpx;
  background: #e9ecf2;
  border-radius: 22rpx;
}

.message-tab {
  flex: 1;
  height: 76rpx;
  color: #6e7789;
  font-size: 26rpx;
  line-height: 76rpx;
  text-align: center;
  border-radius: 18rpx;
}

.message-tab--active {
  color: #2d374b;
  font-weight: 650;
  background: #fff;
  box-shadow: 0 5rpx 14rpx rgba(52, 63, 88, 0.08);
}

.messages-warning {
  display: flex;
  align-items: center;
  min-height: 76rpx;
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  color: #806834;
  font-size: 22rpx;
  line-height: 1.45;
  background: #fff7df;
  border: 1rpx solid #f1dfaa;
  border-radius: 20rpx;
}

.messages-warning__icon {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  margin-right: 12rpx;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  background: #d49b31;
  border-radius: 50%;
}

.messages-warning > text:nth-child(2) {
  flex: 1;
  min-width: 0;
}

.messages-warning__retry {
  flex: 0 0 auto;
  margin-left: 12rpx;
  padding: 14rpx 10rpx;
  color: #3478f6;
  font-weight: 650;
}

.messages-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 380rpx;
  padding: 40rpx;
  color: #747f92;
  font-size: 26rpx;
  line-height: 1.6;
  text-align: center;
}

.messages-state__title {
  margin-bottom: 12rpx;
  color: #27334a;
  font-size: 34rpx;
  font-weight: 700;
}

.messages-state button {
  min-width: 208rpx;
  height: 80rpx;
  margin-top: 26rpx;
  color: #fff;
  font-size: 25rpx;
  line-height: 80rpx;
  background: #3478f6;
  border-radius: 999rpx;
}

.messages-spinner {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 18rpx;
  border: 5rpx solid #dce6f8;
  border-top-color: #3478f6;
  border-radius: 50%;
  animation: messages-spin 800ms linear infinite;
}

@keyframes messages-spin {
  to { transform: rotate(360deg); }
}

.message-list { margin-top: 18rpx; }

.message-card {
  display: flex;
  align-items: center;
  min-height: 148rpx;
  margin-bottom: 14rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid #eceef3;
  border-radius: 26rpx;
}

.message-card--unread {
  background: #fff;
  border-color: #e1e9fb;
  box-shadow: 0 10rpx 24rpx rgba(39, 53, 84, 0.07);
}

.message-card--pressed { opacity: 0.76; }

.message-card__avatar {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 82rpx;
  height: 82rpx;
  margin-right: 20rpx;
  overflow: hidden;
  color: #fff;
  font-size: 29rpx;
  font-weight: 700;
  border-radius: 27rpx;
}

.message-card__avatar--image { padding: 0; }
.message-card__avatar--green { background: linear-gradient(145deg, #2ac071, #159a55); }
.message-card__avatar--blue { background: linear-gradient(145deg, #4692ff, #3169e9); }
.message-card__avatar--purple { background: linear-gradient(145deg, #8d70ed, #654fcf); }
.message-card__avatar--orange { background: linear-gradient(145deg, #f4b153, #e2862c); }

.message-card__main {
  flex: 1;
  min-width: 0;
}

.message-card__title-row {
  display: flex;
  align-items: center;
}

.message-card__title {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #2a3347;
  font-size: 28rpx;
  font-weight: 650;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.message-card__meta {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  margin-left: 14rpx;
}

.message-card__time {
  color: #929bab;
  font-size: 21rpx;
  white-space: nowrap;
}

.message-card__badge {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 36rpx;
  height: 36rpx;
  margin-left: 10rpx;
  padding: 0 8rpx;
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  background: #ef625b;
  border: 3rpx solid #fff;
  border-radius: 999rpx;
}

.message-card__preview {
  display: flex;
  align-items: flex-start;
  min-width: 0;
  margin-top: 10rpx;
}

.message-card__role {
  flex: 0 0 auto;
  height: 34rpx;
  margin: 1rpx 10rpx 0 0;
  padding: 0 10rpx;
  font-size: 18rpx;
  font-weight: 650;
  line-height: 34rpx;
  border-radius: 999rpx;
}

.message-card__role--parent {
  color: #4c6fc4;
  background: #eaf1ff;
}

.message-card__role--teacher {
  color: #7753b8;
  background: #f1eaff;
}

.message-card__content {
  display: -webkit-box;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  margin-top: 0;
  color: #737e91;
  font-size: 24rpx;
  line-height: 1.5;
  overflow-wrap: anywhere;
  text-overflow: ellipsis;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.messages-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 28rpx;
}

.messages-empty__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  color: #7f9fe9;
  font-size: 56rpx;
  background: linear-gradient(145deg, #f1f5ff, #e8efff);
  border-radius: 40rpx;
}

.messages-empty__title {
  margin-top: 26rpx;
  color: #3a4355;
  font-size: 29rpx;
  font-weight: 650;
}

.messages-empty__copy {
  max-width: 570rpx;
  margin-top: 12rpx;
  color: #8993a5;
  font-size: 23rpx;
  line-height: 1.6;
  text-align: center;
}

.message-safety {
  display: flex;
  align-items: flex-start;
  margin: 30rpx 4rpx 0;
  padding: 22rpx;
  color: #747f92;
  font-size: 22rpx;
  line-height: 1.6;
  background: #eceff4;
  border-radius: 20rpx;
}

.message-safety__icon {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  margin-right: 12rpx;
  color: #fff;
  font-size: 18rpx;
  background: #6f7c91;
  border-radius: 50%;
}

@media (max-width: 340px) {
  .messages-page { padding-right: 18rpx; padding-left: 18rpx; }
  .messages-header__action { min-width: 132rpx; padding: 0 18rpx; }
  .message-tool { padding: 17rpx 14rpx; }
  .message-tool__icon { width: 60rpx; height: 60rpx; margin-right: 10rpx; }
  .message-card { padding-right: 18rpx; padding-left: 18rpx; }
  .message-card__avatar { width: 72rpx; height: 72rpx; margin-right: 14rpx; }
  .message-card__time { font-size: 19rpx; }
}
