.map-page {
  overflow: hidden;
  height: 100vh;
  padding-bottom: calc(112rpx + env(safe-area-inset-bottom));
  background: #e9ecf1;
}

.map-toolbar {
  position: fixed;
  top: 0;
  right: 0;
  left: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: rgba(245, 246, 250, 0.94);
}

.map-search {
  display: flex;
  flex: 1;
  align-items: center;
  height: 76rpx;
  padding: 0 22rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 22rpx rgba(50, 61, 85, 0.1);
}

.map-search__icon {
  margin-right: 12rpx;
  color: #8d95a5;
  font-size: 31rpx;
}

.map-search__input {
  flex: 1;
  height: 76rpx;
  color: #273044;
  font-size: 24rpx;
}

.map-search__placeholder {
  color: #a8aebb;
}

.district-picker {
  margin-left: 14rpx;
}

.district-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  color: #3478f6;
  font-size: 34rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 22rpx rgba(50, 61, 85, 0.1);
}

.map-canvas {
  position: relative;
  overflow: hidden;
  height: 100%;
  background: linear-gradient(145deg, #eef1f4 0%, #e2e6eb 100%);
}

.map-water {
  position: absolute;
  background: rgba(127, 189, 221, 0.28);
  border-radius: 999rpx;
  transform: rotate(-18deg);
}

.map-water--one {
  top: -80rpx;
  right: -180rpx;
  width: 330rpx;
  height: 920rpx;
}

.map-water--two {
  bottom: -280rpx;
  left: -90rpx;
  width: 250rpx;
  height: 700rpx;
}

.map-road {
  position: absolute;
  height: 18rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 2rpx solid rgba(203, 209, 217, 0.5);
  border-radius: 999rpx;
  transform-origin: center;
}

.map-road--one {
  top: 34%;
  left: -8%;
  width: 120%;
  transform: rotate(14deg);
}

.map-road--two {
  top: 58%;
  left: -5%;
  width: 115%;
  transform: rotate(-11deg);
}

.map-road--three {
  top: 10%;
  left: 48%;
  width: 96%;
  transform: rotate(88deg);
}

.map-road--four {
  top: 18%;
  left: 5%;
  width: 75%;
  transform: rotate(60deg);
}

.map-label {
  position: absolute;
  color: rgba(96, 105, 119, 0.52);
  font-size: 20rpx;
  letter-spacing: 2rpx;
}

.map-label--one { top: 28%; left: 16%; }
.map-label--two { top: 51%; left: 62%; }
.map-label--three { top: 73%; left: 32%; }

.price-marker {
  position: absolute;
  z-index: 4;
  display: flex;
  align-items: center;
  min-width: 96rpx;
  height: 52rpx;
  padding: 0 14rpx;
  color: #d18a22;
  font-size: 22rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 18rpx 18rpx 18rpx 4rpx;
  box-shadow: 0 8rpx 20rpx rgba(66, 74, 92, 0.14);
  transform: translate(-50%, -50%);
}

.price-marker--active {
  color: #ffffff;
  background: #3478f6;
  box-shadow: 0 10rpx 24rpx rgba(52, 120, 246, 0.32);
  transform: translate(-50%, -50%) scale(1.12);
}

.price-marker--pressed {
  opacity: 0.76;
}

.price-marker__dot {
  width: 18rpx;
  height: 18rpx;
  margin-left: 8rpx;
  border-radius: 50%;
}

.price-marker--active .price-marker__dot {
  background: #ffffff !important;
}

.map-controls {
  position: absolute;
  right: 24rpx;
  bottom: 226rpx;
  z-index: 7;
}

.map-control {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  margin-top: 12rpx;
  color: #596275;
  font-size: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 22rpx;
  box-shadow: 0 8rpx 20rpx rgba(50, 62, 90, 0.12);
}

.map-job-card {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  left: 24rpx;
  z-index: 6;
  display: flex;
  align-items: center;
  min-height: 150rpx;
  padding: 22rpx;
  background: rgba(255, 255, 255, 0.97);
  border-radius: 28rpx;
  box-shadow: 0 16rpx 36rpx rgba(46, 58, 86, 0.16);
}

.map-job-card--pressed {
  opacity: 0.86;
  transform: scale(0.99);
}

.map-job-card__icon {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 78rpx;
  height: 78rpx;
  margin-right: 18rpx;
  color: #3478f6;
  font-size: 35rpx;
  background: #edf4ff;
  border-radius: 22rpx;
}

.map-job-card__main {
  flex: 1;
  min-width: 0;
}

.map-job-card__title-row {
  display: flex;
  align-items: center;
}

.map-job-card__code {
  margin-right: 8rpx;
  color: #99a0ae;
  font-size: 18rpx;
}

.map-job-card__title {
  overflow: hidden;
  flex: 1;
  color: #242d40;
  font-size: 25rpx;
  font-weight: 650;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.map-job-card__meta {
  display: block;
  margin-top: 12rpx;
  color: #7d8698;
  font-size: 20rpx;
}

.map-job-card__price {
  display: flex;
  flex: 0 0 auto;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 12rpx;
  color: #e88a28;
  font-size: 30rpx;
  font-weight: 750;
}

.map-job-card__unit {
  color: #9097a5;
  font-size: 17rpx;
  font-weight: 400;
}

.nearby-list {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  left: 24rpx;
  z-index: 8;
  overflow: hidden;
  height: 480rpx;
  background: rgba(255, 255, 255, 0.98);
  border-radius: 30rpx;
  box-shadow: 0 18rpx 42rpx rgba(42, 54, 79, 0.2);
}

.nearby-list__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 82rpx;
  padding: 0 26rpx;
  color: #2d3548;
  font-size: 24rpx;
  font-weight: 650;
  border-bottom: 1rpx solid #eef0f4;
}

.nearby-list__head text:last-child {
  color: #3478f6;
  font-size: 21rpx;
  font-weight: 400;
}

.nearby-list__scroll {
  height: 398rpx;
}

.nearby-list__item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 100rpx;
  padding: 20rpx 26rpx;
  border-bottom: 1rpx solid #f0f2f5;
}

.nearby-list__item--active {
  background: #f2f7ff;
}

.nearby-list__title,
.nearby-list__meta {
  display: block;
}

.nearby-list__title {
  overflow: hidden;
  max-width: 470rpx;
  color: #333b4e;
  font-size: 23rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nearby-list__meta {
  margin-top: 8rpx;
  color: #939aa8;
  font-size: 19rpx;
}

.nearby-list__price {
  color: #e58b29;
  font-size: 26rpx;
  font-weight: 700;
}

.map-empty {
  position: absolute;
  top: 45%;
  left: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #7d8695;
  font-size: 23rpx;
  transform: translate(-50%, -50%);
}

.map-empty__icon {
  margin-bottom: 14rpx;
  color: #9aa5b7;
  font-size: 60rpx;
}
