<view class="page-with-tabbar map-page">
  <view class="map-toolbar">
    <view class="map-search"><text class="map-search__icon">⌕</text><input class="map-search__input" value="{{query}}" placeholder="搜索科目 / 地区 / 标题" bindinput="handleSearch" /><text wx:if="{{query}}" class="map-search__clear" bindtap="clearSearch" aria-label="清空搜索">×</text></view>
    <picker class="district-picker" range="{{districts}}" value="{{districtIndex}}" bindchange="changeDistrict"><view class="district-button">{{districts[districtIndex]}}⌄</view></picker>
  </view>

  <view class="map-state" wx:if="{{loading}}"><view class="map-spinner"></view><text>正在获取真实位置和附近信息...</text></view>
  <view class="map-state" wx:elif="{{error}}"><text class="map-state__title">加载失败</text><text>{{error}}</text><button bindtap="retry">重新加载</button></view>
  <block wx:else>
    <view class="fallback-layout" wx:if="{{fallbackMode}}">
      <view class="location-fallback">
        <view class="location-fallback__icon">⌖</view>
        <view class="location-fallback__main"><text class="location-fallback__title">没有定位，也能安心找家教</text><text class="location-fallback__copy">{{fallbackReason}}</text></view>
        <view class="location-fallback__actions"><button wx:if="{{locationPermissionDenied}}" bindtap="openLocationSetting">去设置</button><button class="location-fallback__retry" bindtap="resetLocation">重试定位</button></view>
      </view>
      <view class="nearby-panel nearby-panel--fallback">
        <view class="nearby-panel__head"><text>数据库列表 · {{visibleJobs.length}} 条</text></view>
        <scroll-view class="nearby-panel__scroll" scroll-y>
          <view class="nearby-item {{selectedJob && selectedJob.id === item.id ? 'nearby-item--active' : ''}}" wx:for="{{visibleJobs}}" wx:key="id" data-id="{{item.id}}" bindtap="selectFromList">
            <view class="nearby-item__main"><text class="nearby-item__title">{{item.title}}</text><text class="nearby-item__meta">{{item.locationLabel || '地点待沟通'}} · {{item.subject}}</text></view><text class="nearby-item__price">¥{{item.price}}</text><button data-id="{{item.id}}" catchtap="openDetail">查看</button>
          </view>
          <view class="map-empty" wx:if="{{!visibleJobs.length}}"><view class="map-empty__icon">⌕</view><text>{{jobs.length ? '没有符合当前筛选的信息' : '数据库中暂无已发布信息'}}</text><button wx:if="{{jobs.length}}" bindtap="resetFilters">清除筛选</button></view>
        </scroll-view>
      </view>
    </view>

    <block wx:else>
      <map class="native-map" latitude="{{latitude}}" longitude="{{longitude}}" markers="{{markers}}" scale="12" show-location enable-3D="false" bindmarkertap="selectMarker"></map>
      <view class="map-controls"><button bindtap="resetLocation" aria-label="重新定位">◎</button><button bindtap="toggleList" aria-label="查看列表">≡</button></view>

      <view class="nearby-panel" wx:if="{{showList}}">
        <view class="nearby-panel__head"><text>附近信息 · {{visibleJobs.length}} 条</text><text bindtap="toggleList">收起</text></view>
        <scroll-view class="nearby-panel__scroll" scroll-y>
          <view class="nearby-item {{selectedJob && selectedJob.id === item.id ? 'nearby-item--active' : ''}}" wx:for="{{visibleJobs}}" wx:key="id" data-id="{{item.id}}" bindtap="selectFromList">
            <view class="nearby-item__main"><text class="nearby-item__title">{{item.title}}</text><text class="nearby-item__meta">{{item.locationLabel || '地点待沟通'}} · {{item.subject}}</text></view><text class="nearby-item__price">¥{{item.price}}</text><button data-id="{{item.id}}" catchtap="openDetail">查看</button>
          </view>
          <view class="map-empty" wx:if="{{!visibleJobs.length}}"><view class="map-empty__icon">⌕</view><text>{{jobs.length ? '没有符合当前筛选的信息' : '数据库中暂无已发布信息'}}</text><button wx:if="{{jobs.length}}" bindtap="resetFilters">清除筛选</button></view>
        </scroll-view>
      </view>

      <view class="selected-card" wx:if="{{selectedJob && !showList}}" data-id="{{selectedJob.id}}" bindtap="openDetail">
        <view class="selected-card__main"><text class="selected-card__type">{{selectedJob.typeLabel}}</text><text class="selected-card__title">{{selectedJob.title}}</text><text class="selected-card__meta">{{selectedJob.locationLabel}} · {{selectedJob.distance || '距离计算中'}}</text></view><view class="selected-card__price">¥{{selectedJob.price}}<text>{{selectedJob.unit}}</text></view>
      </view>
      <view class="map-empty-card" wx:if="{{!visibleJobs.length}}"><text>{{jobs.length ? '没有符合当前筛选的信息' : '当前位置附近暂无带坐标的已发布信息'}}</text><button bindtap="toggleList">{{jobs.length ? '调整筛选' : '查看列表'}}</button></view>
    </block>
  </block>
</view>
