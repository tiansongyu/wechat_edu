.teacher-profile-page { min-height: 100vh; padding-bottom: 60rpx; background: #f5f6fa; }
.cert-hero { position: relative; padding: 48rpx 34rpx 90rpx; color: #fff; background: linear-gradient(140deg, #286ff0, #6159dc); border-radius: 0 0 48rpx 48rpx; }
.cert-hero__eyebrow, .cert-hero__title, .cert-hero__copy { display: block; }.cert-hero__eyebrow { color: rgba(255,255,255,.58); font-size: 18rpx; letter-spacing: 3rpx; }.cert-hero__title { margin-top: 12rpx; font-size: 42rpx; font-weight: 750; }.cert-hero__copy { margin-top: 13rpx; color: rgba(255,255,255,.72); font-size: 21rpx; }
.cert-status { position: absolute; right: 32rpx; bottom: 26rpx; padding: 10rpx 18rpx; font-size: 19rpx; background: rgba(255,255,255,.16); border: 1rpx solid rgba(255,255,255,.25); border-radius: 999rpx; }.cert-status--APPROVED { color: #1b7045; background: #b7f1ce; border-color: transparent; }.cert-status--REJECTED { color: #9f3434; background: #ffd3d3; border-color: transparent; }
.cert-content { position: relative; z-index: 2; margin-top: -52rpx; padding: 0 24rpx; }.cert-card { margin-bottom: 20rpx; padding: 28rpx; background: #fff; border: 1rpx solid #e9edf3; border-radius: 28rpx; box-shadow: 0 12rpx 30rpx rgba(43,58,91,.05); }.cert-card__head { display: flex; align-items: center; justify-content: space-between; }.cert-card__title { color: #283248; font-size: 28rpx; font-weight: 700; }.cert-card__count { color: #8992a4; font-size: 19rpx; }
.cert-grid { display: flex; gap: 16rpx; }.cert-grid .cert-field { flex: 1; }.cert-field { margin-top: 24rpx; }.cert-field > text { display: block; margin-bottom: 11rpx; color: #5b6476; font-size: 21rpx; font-weight: 600; }.cert-field input, .cert-field textarea { width: 100%; padding: 0 20rpx; color: #283248; font-size: 23rpx; background: #f7f8fa; border: 1rpx solid #e8ebf0; border-radius: 18rpx; }.cert-field input { height: 80rpx; }.cert-field textarea { height: 170rpx; padding-top: 18rpx; }
.cert-file { display: flex; align-items: center; min-height: 82rpx; margin-top: 15rpx; padding: 0 16rpx; background: #f7f9fc; border-radius: 17rpx; }.cert-file > view { margin-right: 13rpx; color: #3478f6; }.cert-file > text { flex: 1; color: #465168; font-size: 21rpx; }.cert-file .cert-file__status { flex: 0 0 auto; color: #8a94a7; font-size: 18rpx; }
.upload-button { height: 82rpx; margin-top: 20rpx; color: #3478f6; font-size: 22rpx; line-height: 82rpx; background: #edf4ff; border-radius: 18rpx; }.upload-tip { display: block; margin-top: 12rpx; color: #a4aab6; font-size: 17rpx; text-align: center; }.save-button { height: 92rpx; color: #fff; font-size: 25rpx; font-weight: 700; line-height: 92rpx; background: linear-gradient(100deg, #2f83f7, #5262eb); border-radius: 22rpx; box-shadow: 0 13rpx 28rpx rgba(51,111,239,.25); }.cert-loading { padding-top: 180rpx; color: #949dab; font-size: 23rpx; text-align: center; }
