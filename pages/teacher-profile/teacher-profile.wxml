<view class="teacher-profile-page">
  <view class="cert-hero">
    <text class="cert-hero__eyebrow">TEACHER VERIFICATION</text>
    <text class="cert-hero__title">教师认证资料</text>
    <text class="cert-hero__copy">真实完整的资料会获得更高曝光和家长信任</text>
    <view class="cert-status cert-status--{{auditStatusTone}}">{{auditStatusLabel}}</view>
    <text class="cert-audit-note" wx:if="{{profile && profile.auditNote}}">审核意见：{{profile.auditNote}}</text>
  </view>

  <view class="cert-error" wx:if="{{!loading && error}}"><text>资料加载失败</text><text>{{error}}</text><button bindtap="retry">重新加载</button></view>
  <view class="cert-content" wx:elif="{{!loading}}">
    <view class="cert-card">
      <text class="cert-card__title">基本身份</text>
      <view class="cert-grid">
        <view class="cert-field"><text>真实姓名 *</text><input value="{{form.realName}}" data-field="realName" placeholder="用于平台认证" bindinput="handleInput" /></view>
        <view class="cert-field"><text>最高学历 *</text><input value="{{form.education}}" data-field="education" placeholder="例如：本科" bindinput="handleInput" /></view>
      </view>
      <view class="cert-field"><text>学校 *</text><input value="{{form.school}}" data-field="school" placeholder="请输入学校全称" bindinput="handleInput" /></view>
      <view class="cert-field"><text>专业 *</text><input value="{{form.major}}" data-field="major" placeholder="例如：数学教育" bindinput="handleInput" /></view>
    </view>

    <view class="cert-card">
      <text class="cert-card__title">教学能力</text>
      <view class="cert-grid">
        <view class="cert-field"><text>教学年限</text><input value="{{form.teachingYears}}" type="number" data-field="teachingYears" placeholder="0" bindinput="handleInput" /></view>
        <view class="cert-field"><text>参考课酬</text><input value="{{form.hourlyRate}}" type="number" data-field="hourlyRate" placeholder="元/小时" bindinput="handleInput" /></view>
      </view>
      <view class="cert-field"><text>擅长科目 *</text><input value="{{form.subjects}}" data-field="subjects" placeholder="数学、物理（用顿号分隔）" bindinput="handleInput" /></view>
      <view class="cert-field"><text>对外展示标题</text><input value="{{form.displayTitle}}" data-field="displayTitle" maxlength="120" placeholder="例如：5年初高中数学提分老师" bindinput="handleInput" /></view>
      <view class="cert-field"><text>服务区域</text><picker mode="region" value="{{serviceRegionValue}}" bindchange="addServiceRegion"><view class="service-region-picker">＋ 使用省 / 市 / 区滚动控件添加</view></picker><view class="service-region-list"><view class="service-region-tag" wx:for="{{form.serviceAreas}}" wx:key="label"><text>{{item.label}}</text><text data-index="{{index}}" bindtap="removeServiceRegion">×</text></view><text class="service-region-empty" wx:if="{{!form.serviceAreas.length}}">尚未选择服务区域</text></view></view>
      <view class="cert-field"><text>授课方式（可多项）</text><input value="{{form.serviceModes}}" data-field="serviceModes" placeholder="上门、在线、到老师处" bindinput="handleInput" /></view>
      <view class="cert-field"><text>可授课时间（可多项）</text><input value="{{form.availableTimes}}" data-field="availableTimes" placeholder="工作日晚间、周六上午" bindinput="handleInput" /></view>
      <view class="cert-field"><text>语言能力（可多项）</text><input value="{{form.languages}}" data-field="languages" placeholder="普通话、英语" bindinput="handleInput" /></view>
      <view class="cert-field"><text>课程形式（可多项）</text><input value="{{form.lessonFormats}}" data-field="lessonFormats" placeholder="一对一、小班、作业答疑" bindinput="handleInput" /></view>
      <view class="cert-field"><text>个人简介</text><textarea value="{{form.bio}}" data-field="bio" maxlength="500" placeholder="介绍教学经验和教学方法" bindinput="handleInput"></textarea></view>
      <view class="cert-field"><text>教学风格</text><textarea value="{{form.teachingStyle}}" data-field="teachingStyle" maxlength="1000" placeholder="如何诊断问题、讲解与反馈" bindinput="handleInput"></textarea></view>
      <view class="cert-field"><text>教学成果</text><textarea value="{{form.teachingAchievements}}" data-field="teachingAchievements" maxlength="1000" placeholder="用匿名、可验证的方式描述代表性成果" bindinput="handleInput"></textarea></view>
      <view class="cert-field"><text>考试与课程经验</text><textarea value="{{form.examExperience}}" data-field="examExperience" maxlength="1000" placeholder="熟悉的教材版本、考试体系或竞赛经验" bindinput="handleInput"></textarea></view>
    </view>

    <view class="cert-card">
      <view class="cert-card__head"><text class="cert-card__title">认证材料</text><text class="cert-card__count">{{certifications.length}} 份</text></view>
      <view class="cert-file" wx:for="{{certifications}}" wx:key="id"><view>▤</view><text>{{item.type}}</text><text class="cert-file__status">{{item.auditStatus === 'APPROVED' ? '已通过' : item.auditStatus === 'REJECTED' ? '需修改' : '审核中'}}</text></view>
      <button class="upload-button" bindtap="chooseCertification">＋ 上传学历 / 教师资格证明</button>
      <text class="upload-tip">支持 JPG、PNG、PDF，单个文件不超过 10MB</text>
    </view>

    <button class="save-button" loading="{{saving}}" bindtap="saveProfile">保存并提交审核</button>
  </view>
  <view class="cert-loading" wx:else>正在加载教师资料...</view>
</view>
