.reviews-page { min-height: 100vh; color: #283249; background: #f5f7fb; }
.review-hero { position: relative; overflow: hidden; min-height: 330rpx; padding: 38rpx 30rpx 56rpx; color: #fff; background: linear-gradient(145deg, #377ef5 0%, #5f62ec 62%, #8763e7 100%); border-radius: 0 0 52rpx 52rpx; }
.review-hero__glow { position: absolute; top: -180rpx; right: -130rpx; width: 430rpx; height: 430rpx; background: rgba(255, 255, 255, .09); border-radius: 50%; }
.review-hero__top, .review-hero__score-row { position: relative; z-index: 1; display: flex; align-items: center; }
.review-hero__top { justify-content: space-between; }
.review-hero__eyebrow { color: rgba(255, 255, 255, .78); font-size: 22rpx; }
.review-hero__badge { padding: 8rpx 16rpx; color: #395bc4; font-size: 20rpx; font-weight: 700; background: #dff9bb; border-radius: 999rpx; }
.review-hero__score-row { margin-top: 28rpx; }
.review-hero__score { min-width: 120rpx; font-size: 76rpx; font-weight: 800; line-height: 1; }
.review-hero__score-copy { display: flex; flex-direction: column; gap: 8rpx; padding-left: 20rpx; border-left: 1rpx solid rgba(255, 255, 255, .25); }
.review-hero__score-copy text:first-child { font-size: 27rpx; font-weight: 700; }
.review-hero__score-copy text:last-child { color: rgba(255, 255, 255, .72); font-size: 21rpx; }
.review-hero__privacy { position: relative; z-index: 1; display: block; margin-top: 28rpx; color: rgba(255, 255, 255, .7); font-size: 20rpx; }
.review-content { position: relative; z-index: 2; margin-top: -26rpx; padding: 0 24rpx 48rpx; }
.reputation-alert { display: flex; align-items: center; min-height: 108rpx; margin-bottom: 18rpx; padding: 18rpx 20rpx; background: #fff9ed; border: 1rpx solid #f5dfb4; border-radius: 24rpx; }
.reputation-alert__icon { display: flex; flex: 0 0 auto; align-items: center; justify-content: center; width: 56rpx; height: 56rpx; margin-right: 14rpx; color: #a87017; font-size: 28rpx; font-weight: 800; background: #ffedc8; border-radius: 18rpx; }
.reputation-alert__main { flex: 1; min-width: 0; }
.reputation-alert__title, .reputation-alert__copy { display: block; }
.reputation-alert__title { color: #68502b; font-size: 22rpx; font-weight: 700; }
.reputation-alert__copy { margin-top: 5rpx; color: #907b59; font-size: 20rpx; line-height: 1.45; }
.reputation-alert button { width: auto; min-width: 142rpx; height: 80rpx; margin: 0 0 0 14rpx; padding: 0 18rpx; color: #3e69c4; font-size: 20rpx; line-height: 80rpx; background: #edf4ff; border-radius: 20rpx; }
.review-form, .review-list-card { padding: 28rpx; background: #fff; border: 1rpx solid #e9edf4; border-radius: 30rpx; box-shadow: 0 14rpx 34rpx rgba(34, 49, 83, .07); }
.review-list-card { margin-top: 22rpx; }
.section-heading { display: flex; align-items: flex-start; justify-content: space-between; }
.section-heading__title, .section-heading__copy { display: block; }
.section-heading__title { color: #283249; font-size: 29rpx; font-weight: 750; }
.section-heading__copy { margin-top: 8rpx; color: #8993a5; font-size: 20rpx; line-height: 1.55; }
.section-heading__flower { color: #886de9; font-size: 38rpx; }
.star-picker { display: flex; align-items: center; justify-content: center; margin-top: 28rpx; gap: 10rpx; }
.star-picker__item { display: flex; align-items: center; justify-content: center; width: 88rpx; height: 88rpx; color: #d8deea; font-size: 62rpx; }
.star-picker__star--active { color: #ffbd3f; text-shadow: 0 6rpx 14rpx rgba(239, 161, 20, .22); }
.rating-hint { display: block; min-height: 36rpx; margin-top: 10rpx; color: #69758a; font-size: 21rpx; text-align: center; }
.review-form__label { display: block; margin-top: 30rpx; color: #3d485e; font-size: 23rpx; font-weight: 700; }
.review-form__label > text { margin-left: 8rpx; color: #a1a8b5; font-size: 20rpx; font-weight: 400; }
.tag-picker { display: flex; flex-wrap: wrap; margin-top: 14rpx; gap: 12rpx; }
.tag-chip { display: flex; align-items: center; min-height: 80rpx; padding: 0 22rpx; color: #69758a; font-size: 21rpx; background: #f3f6fb; border: 2rpx solid transparent; border-radius: 999rpx; }
.tag-chip--active { color: #3c6dde; background: #edf4ff; border-color: #91b9ff; }
.review-form__label-row { display: flex; align-items: center; justify-content: space-between; }
.review-form__count { margin-top: 30rpx; color: #a1a9b7; font-size: 20rpx; }
.review-textarea { width: 100%; height: 230rpx; margin-top: 14rpx; padding: 20rpx; color: #344057; font-size: 23rpx; line-height: 1.65; background: #f7f9fc; border: 2rpx solid #e4e9f1; border-radius: 20rpx; }
.review-textarea__placeholder { color: #adb4c0; }
.review-guidance { display: flex; align-items: flex-start; margin-top: 16rpx; padding: 16rpx 18rpx; color: #748096; font-size: 20rpx; line-height: 1.55; background: #f1f7f4; border-radius: 16rpx; gap: 10rpx; }
.review-form__error { display: block; margin-top: 14rpx; color: #c95757; font-size: 21rpx; }
.review-submit, .load-more, .review-state button { height: 88rpx; margin-top: 24rpx; color: #fff; font-size: 25rpx; font-weight: 650; line-height: 88rpx; background: linear-gradient(90deg, #3478f6, #665deb); border-radius: 22rpx; }
.review-success, .review-waiting { display: flex; align-items: center; min-height: 128rpx; padding: 24rpx; background: #fff; border: 1rpx solid #e8edf4; border-radius: 28rpx; box-shadow: 0 12rpx 30rpx rgba(38, 54, 86, .06); }
.review-success__icon, .review-waiting__icon { display: flex; flex: 0 0 auto; align-items: center; justify-content: center; width: 68rpx; height: 68rpx; margin-right: 18rpx; color: #fff; font-size: 32rpx; background: linear-gradient(145deg, #3cc279, #23a96a); border-radius: 22rpx; }
.review-waiting__icon { color: #9b6c17; background: #fff4dc; }
.review-success__main, .review-waiting view { flex: 1; }
.review-success__title, .review-success__copy, .review-waiting__title, .review-waiting__copy { display: block; }
.review-success__title, .review-waiting__title { color: #344057; font-size: 24rpx; font-weight: 700; }
.review-success__copy, .review-waiting__copy { margin-top: 7rpx; color: #8a94a4; font-size: 20rpx; line-height: 1.5; }
.review-success__rating { margin-left: 12rpx; color: #e49a22; font-size: 22rpx; font-weight: 700; }
.review-count { color: #66738a; font-size: 21rpx; }
.review-context-summary { display: flex; align-items: flex-start; margin-top: 20rpx; padding: 18rpx; color: #66758c; font-size: 20rpx; line-height: 1.55; background: #f3f7fc; border-radius: 18rpx; gap: 10rpx; }
.review-item { padding: 26rpx 0; border-top: 1rpx solid #edf0f5; }
.review-item:first-of-type { margin-top: 20rpx; }
.review-item__head { display: flex; align-items: flex-start; justify-content: space-between; }
.review-item__author { color: #364157; font-size: 23rpx; font-weight: 700; }
.review-item__stars { display: flex; margin-top: 7rpx; color: #d9dee8; font-size: 22rpx; gap: 3rpx; }
.review-item__stars .is-filled { color: #ffb936; }
.review-item__date { color: #9aa3b1; font-size: 20rpx; }
.review-item__tags { display: flex; flex-wrap: wrap; margin-top: 14rpx; gap: 8rpx; }
.review-item__tags text { padding: 6rpx 12rpx; color: #5574b1; font-size: 20rpx; background: #eff5ff; border-radius: 9rpx; }
.review-item__content { display: block; margin-top: 14rpx; color: #626e82; font-size: 22rpx; line-height: 1.75; }
.review-empty { display: flex; flex-direction: column; align-items: center; padding: 54rpx 18rpx 36rpx; text-align: center; }
.review-empty__planet { color: #9eb9ef; font-size: 54rpx; }
.review-empty__title, .review-empty__copy { display: block; }
.review-empty__title { margin-top: 14rpx; color: #4a566b; font-size: 24rpx; font-weight: 700; }
.review-empty__copy { margin-top: 10rpx; color: #939cab; font-size: 20rpx; line-height: 1.55; }
.load-more { width: 100%; color: #4b70c5; background: #edf4ff; box-shadow: none; }
.review-state { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 76vh; padding: 46rpx; color: #788499; font-size: 22rpx; text-align: center; }
.review-state__emoji { color: #9ab4e7; font-size: 66rpx; }
.review-state__title { margin-top: 16rpx; color: #303c53; font-size: 30rpx; font-weight: 750; }
.review-state__copy { margin-top: 12rpx; font-size: 21rpx; line-height: 1.6; }
.review-state button { min-width: 260rpx; }
.review-spinner { width: 48rpx; height: 48rpx; margin-bottom: 20rpx; border: 5rpx solid #dce5f6; border-top-color: #4b72ee; border-radius: 50%; animation: review-spin 800ms linear infinite; }
@keyframes review-spin { to { transform: rotate(360deg); } }
@media (max-width: 340px) { .star-picker { gap: 2rpx; } .star-picker__item { width: 76rpx; }.review-content { padding-right: 18rpx; padding-left: 18rpx; } }
