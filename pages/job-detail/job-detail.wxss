.detail-page {
  min-height: 100vh;
  padding-bottom: calc(132rpx + env(safe-area-inset-bottom));
  background: #f5f6fa;
}

.detail-hero {
  position: relative;
  overflow: hidden;
  min-height: 350rpx;
  padding: 36rpx 30rpx 46rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #2c72ef 0%, #4e62e9 58%, #715bdd 100%);
  border-radius: 0 0 48rpx 48rpx;
}

.detail-hero::after {
  position: absolute;
  top: -200rpx;
  right: -160rpx;
  width: 500rpx;
  height: 500rpx;
  content: "";
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.detail-hero__meta {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  color: rgba(255, 255, 255, 0.72);
  font-size: 21rpx;
}

.detail-hero__code {
  margin-right: 12rpx;
  padding: 5rpx 10rpx;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 8rpx;
}

.detail-hero__title {
  position: relative;
  z-index: 2;
  display: block;
  max-width: 620rpx;
  margin-top: 22rpx;
  font-size: 40rpx;
  font-weight: 750;
  line-height: 1.4;
}

.detail-hero__price-row {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: 24rpx;
}

.detail-hero__price {
  color: #ffe6a9;
  font-size: 27rpx;
  font-weight: 650;
}

.detail-hero__price > text:first-child {
  font-size: 52rpx;
  font-weight: 800;
}

.detail-hero__unit {
  margin-left: 5rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 20rpx;
  font-weight: 400;
}

.detail-hero__status {
  padding: 9rpx 15rpx;
  color: #ffffff;
  font-size: 19rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  border-radius: 999rpx;
}

.detail-hero__tags {
  position: relative;
  z-index: 2;
  display: flex;
  flex-wrap: wrap;
  margin-top: 22rpx;
}

.detail-hero__tags text {
  margin: 0 10rpx 8rpx 0;
  padding: 7rpx 13rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 18rpx;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 9rpx;
}

.detail-content {
  padding: 22rpx 24rpx;
}

.publisher-card {
  display: flex;
  align-items: center;
  min-height: 122rpx;
  padding: 22rpx;
  background: #ffffff;
  border: 1rpx solid #eceef3;
  border-radius: 26rpx;
  box-shadow: 0 10rpx 26rpx rgba(42, 56, 88, 0.05);
}

.publisher-card__avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  margin-right: 16rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  background: linear-gradient(145deg, #f3bd55, #e88731);
  border-radius: 24rpx;
}

.publisher-card__main {
  flex: 1;
}

.publisher-card__name-row {
  display: flex;
  align-items: center;
}

.publisher-card__name {
  color: #2b3447;
  font-size: 25rpx;
  font-weight: 650;
}

.publisher-card__verified {
  margin-left: 10rpx;
  padding: 4rpx 9rpx;
  color: #3478f6;
  font-size: 16rpx;
  background: #edf4ff;
  border-radius: 7rpx;
}

.publisher-card__role {
  display: block;
  margin-top: 8rpx;
  color: #939aa8;
  font-size: 18rpx;
}

.publisher-card__contact {
  padding: 10rpx 17rpx;
  color: #3478f6;
  font-size: 20rpx;
  background: #edf4ff;
  border-radius: 999rpx;
}

.detail-card,
.process-card,
.safety-card {
  margin-top: 18rpx;
  padding: 26rpx;
  background: #ffffff;
  border: 1rpx solid #eceef3;
  border-radius: 26rpx;
}

.detail-card__title {
  color: #283145;
  font-size: 27rpx;
  font-weight: 700;
}

.detail-card__description {
  display: block;
  margin-top: 18rpx;
  color: #646d7e;
  font-size: 22rpx;
  line-height: 1.8;
}

.detail-info-row {
  display: flex;
  align-items: center;
  min-height: 100rpx;
  border-top: 1rpx solid #f0f2f5;
}

.detail-info-row:first-of-type {
  margin-top: 20rpx;
}

.detail-info-row__icon {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  margin-right: 15rpx;
  color: #3478f6;
  font-size: 27rpx;
  background: #edf4ff;
  border-radius: 17rpx;
}

.detail-info-row__label,
.detail-info-row__value {
  display: block;
}

.detail-info-row__label {
  color: #8b93a2;
  font-size: 18rpx;
}

.detail-info-row__value {
  margin-top: 5rpx;
  color: #374054;
  font-size: 21rpx;
}

.process-steps {
  display: flex;
  align-items: flex-start;
  margin-top: 28rpx;
}

.process-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #747d8e;
  font-size: 18rpx;
  white-space: nowrap;
}

.process-step__number {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  margin-bottom: 10rpx;
  color: #3478f6;
  font-size: 21rpx;
  font-weight: 700;
  background: #edf4ff;
  border-radius: 50%;
}

.process-line {
  flex: 1;
  height: 2rpx;
  margin: 25rpx 8rpx 0;
  background: #dce5f4;
}

.safety-card {
  display: flex;
  align-items: flex-start;
  color: #687283;
  background: #f0f7f3;
  border-color: #dcefe4;
}

.safety-card__icon {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  margin-right: 15rpx;
  color: #ffffff;
  font-size: 23rpx;
  background: #27a866;
  border-radius: 17rpx;
}

.safety-card__title,
.safety-card__copy {
  display: block;
}

.safety-card__title {
  color: #2f704c;
  font-size: 23rpx;
  font-weight: 650;
}

.safety-card__copy {
  margin-top: 7rpx;
  font-size: 19rpx;
  line-height: 1.65;
}

.detail-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  min-height: 112rpx;
  padding: 14rpx 22rpx calc(14rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid #eceef3;
  box-shadow: 0 -10rpx 28rpx rgba(45, 57, 84, 0.08);
}

.detail-action-icon {
  display: flex;
  flex: 0 0 auto;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 82rpx;
  height: 82rpx;
  margin: 0 12rpx 0 0;
  padding: 0;
  color: #697284;
  font-size: 29rpx;
  line-height: 1;
  background: #f5f6f8;
  border-radius: 20rpx;
}

.detail-action-icon text {
  margin-top: 6rpx;
  font-size: 16rpx;
}

.detail-action-icon--favorite {
  color: #e7625b;
  background: #fff0ef;
}

.detail-apply {
  flex: 1;
  height: 84rpx;
  margin: 0;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 650;
  line-height: 84rpx;
  background: linear-gradient(90deg, #3478f6, #4e5bed);
  border-radius: 22rpx;
  box-shadow: 0 10rpx 22rpx rgba(52, 120, 246, 0.23);
}

.detail-apply--pending {
  background: linear-gradient(90deg, #27ad62, #1bb96b);
  box-shadow: 0 10rpx 22rpx rgba(31, 166, 92, 0.2);
}
