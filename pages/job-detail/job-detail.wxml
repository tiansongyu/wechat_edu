<view class="detail-page">
  <view class="detail-state" wx:if="{{loading}}"><view class="detail-spinner"></view><text>正在加载详情...</text></view>
  <view class="detail-state" wx:elif="{{error}}"><text class="detail-state__title">无法打开这条信息</text><text>{{error}}</text><button bindtap="retry">重新加载</button></view>
  <block wx:elif="{{job}}">
    <view class="detail-hero">
      <view class="detail-hero__meta"><text class="detail-hero__code">{{job.typeLabel}}</text><text class="detail-hero__location">{{job.locationLabel || '地点待沟通'}}{{job.distance ? ' · ' + job.distance : ''}}</text></view>
      <text class="detail-hero__title">{{job.title}}</text>
      <view class="detail-hero__price-row"><view class="detail-hero__price">¥<text>{{job.price}}</text><text class="detail-hero__unit">{{job.unit}}</text></view><view class="detail-hero__status">{{activeRole === 'TEACHER' ? applicationLabel : job.statusLabel}}</view></view>
      <view class="detail-hero__tags"><text>{{job.settlement || '结算待沟通'}}</text><text>{{job.grade}}</text><text>{{job.subject}}</text></view>
    </view>
    <view class="detail-content">
      <view class="publisher-card">
        <image wx:if="{{job.publisherAvatar}}" class="publisher-card__avatar publisher-card__avatar--image" src="{{job.publisherAvatar}}" mode="aspectFill" />
        <view wx:else class="publisher-card__avatar">{{job.publisherInitial}}</view>
        <view class="publisher-card__main"><view class="publisher-card__name-row"><text class="publisher-card__name">{{job.publisher}}</text><text class="publisher-card__verified">{{job.typeLabel}}</text></view><text class="publisher-card__role">{{job.createdLabel ? job.createdLabel + '发布' : '发布时间以平台记录为准'}}</text></view>
        <view class="publisher-card__contact" bindtap="contactPublisher">{{publisherActionLabel}}</view>
      </view>
      <view class="detail-card">
        <text class="detail-card__title">详细说明</text><text class="detail-card__description">{{job.description}}</text>
        <view class="detail-info-row"><view class="detail-info-row__icon">◷</view><view><text class="detail-info-row__label">授课时间</text><text class="detail-info-row__value">{{job.schedule || '待沟通'}}</text></view></view>
        <view class="detail-info-row"><view class="detail-info-row__icon">⌖</view><view><text class="detail-info-row__label">授课地点</text><text class="detail-info-row__value">{{job.address || job.locationLabel || '待沟通'}}</text></view></view>
        <view class="detail-info-row"><view class="detail-info-row__icon">◎</view><view><text class="detail-info-row__label">学生情况</text><text class="detail-info-row__value">{{job.studentInfo || '未填写'}}</text></view></view>
      </view>
      <view class="process-card"><text class="detail-card__title">平台流程</text><view class="process-steps"><view class="process-step"><view class="process-step__number">1</view><text>提交申请</text></view><view class="process-line"></view><view class="process-step"><view class="process-step__number">2</view><text>发布人处理</text></view><view class="process-line"></view><view class="process-step"><view class="process-step__number">3</view><text>平台沟通</text></view><view class="process-line"></view><view class="process-step"><view class="process-step__number">4</view><text>确认合作</text></view></view></view>
      <view class="safety-card"><text class="safety-card__icon">✓</text><view><text class="safety-card__title">平台安全提醒</text><text class="safety-card__copy">请在平台内沟通，不要私下转账或提供验证码。</text></view></view>
      <button wx:if="{{activeRole === 'TEACHER' && currentApplication && currentApplication.status === 'PENDING'}}" class="cancel-application" loading="{{action === 'cancel'}}" bindtap="cancelApplication">取消本次申请</button>
    </view>
    <view class="detail-actions">
      <button class="detail-action-icon {{job.favorite ? 'detail-action-icon--favorite' : ''}}" loading="{{action === 'favorite'}}" bindtap="toggleFavorite">{{job.favorite ? '♥' : '♡'}}<text>收藏</text></button>
      <button class="detail-action-icon" open-type="share">↗<text>分享</text></button>
      <button wx:if="{{canManageApplications}}" class="detail-apply" bindtap="manageApplications">管理报名</button>
      <button wx:elif="{{isOwner}}" class="detail-apply" loading="{{action === 'role'}}" bindtap="openMyPosts">{{ownerRoleMismatch ? (ownerRole === 'TEACHER' ? '切换老师版管理' : '切换家长版管理') : '管理发布'}}</button>
      <button wx:elif="{{activeRole === 'TEACHER' && job.type === 'TEACHING_NEED' && currentApplication && currentApplication.status === 'ACCEPTED'}}" class="detail-apply" loading="{{action === 'contact'}}" bindtap="contactPublisher">联系发布人</button>
      <button wx:elif="{{activeRole === 'TEACHER' && job.type === 'TEACHING_NEED'}}" class="detail-apply {{canApply ? '' : 'detail-apply--pending'}}" loading="{{action === 'apply'}}" bindtap="applyJob">{{applicationActionLabel}}</button>
      <button wx:elif="{{viewerRoleMismatch}}" class="detail-apply" loading="{{action === 'role'}}" bindtap="switchViewerRole">{{expectedViewerRole === 'TEACHER' ? '切换老师版申请' : '切换家长版联系'}}</button>
      <button wx:else class="detail-apply {{canContact ? '' : 'detail-apply--pending'}}" loading="{{action === 'contact'}}" bindtap="contactPublisher">{{contactLabel}}</button>
    </view>
  </block>
</view>
