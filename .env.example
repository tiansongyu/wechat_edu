# Copy to .env for local Docker development. Change every secret before production.
NODE_ENV=development
# Only needed when Docker Desktop is configured with a host-local proxy.
DOCKER_BUILD_PROXY=
GATEWAY_PORT=4000
POSTGRES_PORT=4001
REDIS_PORT=4002
MINIO_API_PORT=4003
MINIO_CONSOLE_PORT=4004
POSTGRES_DB=tutor_link
POSTGRES_USER=tutor
POSTGRES_PASSWORD=change-me-postgres
DATABASE_URL=postgresql://tutor:change-me-postgres@pgbouncer:5432/tutor_link?schema=public
DIRECT_DATABASE_URL=postgresql://tutor:change-me-postgres@postgres:5432/tutor_link?schema=public
REDIS_URL=redis://redis:6379
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-characters
DATA_ENCRYPTION_KEY=change-me-data-encryption-secret-at-least-32-characters
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_DAYS=30
WECHAT_APP_ID=wx02054be10e52aff0
# Obtain this in the WeChat Mini Program admin console and keep it server-side only.
WECHAT_APP_SECRET=
# Use false for real wx.login -> code2Session authentication. Tests may override this to true.
WECHAT_LOGIN_MOCK=false
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin123456!
# Creates exactly one linked business sample. Production compose always overrides this to false.
SEED_DEMO_DATA=true
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=tutor-link
MINIO_REGION=cn-south-1
MINIO_PUBLIC_ENDPOINT=127.0.0.1
MINIO_PUBLIC_PORT=4003
MINIO_PUBLIC_USE_SSL=false
CORS_ORIGINS=http://localhost:4000,http://localhost:5173
